{% comment %}
  Chat Boat App Embed Block
  Target: body (floats on all storefront pages)
{% endcomment %}

<div
  id="pcb-root"
  class="pcb-{{ block.settings.position }}"
  data-bot-name="{{ block.settings.bot_name | escape }}"
  data-subtitle="{{ block.settings.bot_subtitle | escape }}"
  data-welcome="{{ block.settings.welcome_message | escape }}"
  data-color="{{ block.settings.primary_color }}"
  data-position="{{ block.settings.position }}"
  data-btn-size="{{ block.settings.button_size }}"
  data-auto-open="{{ block.settings.open_on_load }}"
  data-show-mobile="{{ block.settings.show_on_mobile }}"
  data-show-product-slider="{{ block.settings.show_product_slider }}"
  data-show-compare-price="{{ block.settings.show_compare_price }}"
  data-product-click-target="{{ block.settings.product_click_target }}"
  data-slider-limit="{{ block.settings.slider_limit }}"
  data-shop="{{ shop.permanent_domain }}"
  data-api-url="{{ block.settings.app_url | default: 'https://product-chat-boat.vercel.app' | strip }}"
  data-show-powered-by="{{ block.settings.show_powered_by }}"
  data-test-mode="{{ block.settings.test_mode }}"
  data-quick-replies="{{ block.settings.quick_replies | escape }}"
  {{ block.shopify_attributes }}
></div>

{% schema %}
{
  "name": "Chat Boat Embed",
  "target": "body",
  "javascript": "chat-widget.js",
  "stylesheet": "chat-widget.css",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "bot_name",
      "label": "Bot Name",
      "default": "Shop Assistant"
    },
    {
      "type": "textarea",
      "id": "welcome_message",
      "label": "Welcome Message",
      "default": "Hi! I am here to help you find the perfect product. What are you looking for today?"
    },
    {
      "type": "text",
      "id": "bot_subtitle",
      "label": "Bot Subtitle",
      "default": "Online now"
    },
    {
      "type": "text",
      "id": "quick_replies",
      "label": "Quick Reply Chips (comma separated)",
      "info": "Shortcut buttons shown to the customer e.g. Best sellers, On sale",
      "default": "Best sellers,What's on sale?,Gift ideas"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#008060"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Widget Position",
      "options": [
        { "value": "bottom-right", "label": "Bottom Right" },
        { "value": "bottom-left", "label": "Bottom Left" }
      ],
      "default": "bottom-right"
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button Size (px)",
      "min": 44,
      "max": 72,
      "step": 4,
      "default": 56
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "open_on_load",
      "label": "Auto-open chat on page load",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on mobile devices",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "test_mode",
      "label": "Enable test mode badge",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_powered_by",
      "label": "Show Powered by footer",
      "default": true
    },
    {
      "type": "header",
      "content": "Product Slider"
    },
    {
      "type": "checkbox",
      "id": "show_product_slider",
      "label": "Show product slider in chat",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_compare_price",
      "label": "Show compare-at price",
      "default": true
    },
    {
      "type": "range",
      "id": "slider_limit",
      "label": "Products per slider",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "product_click_target",
      "label": "Product click behavior",
      "options": [
        { "value": "same-tab", "label": "Open in same tab" },
        { "value": "new-tab", "label": "Open in new tab" }
      ],
      "default": "same-tab"
    },
    {
      "type": "header",
      "content": "API Connection"
    },
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "default": "https://product-chat-boat.vercel.app",
      "info": "Your Shopify app base URL. In dev mode replace with your tunnel URL."
    }
  ]
}
{% endschema %}
